PORT=3000
HOST=0.0.0.0
PROXY_URL=
DOWNLOAD_DIR=./downloads
BROWSER_TIMEOUT_MS=30000
NETWORK_IDLE_MS=2000
DOWNLOAD_TIMEOUT_MS=300000
FFMPEG_PATH=ffmpeg
MAX_CONCURRENT_DOWNLOADS=3
LOG_LEVEL=info

# Host filtering (comma-separated domains)
PREFERRED_HOSTS=
BLOCKED_HOSTS=
ALLOWED_HOSTS=

# Mullvad VPN
MULLVAD_ACCOUNT=
MULLVAD_LOCATION=
MULLVAD_CONFIG_DIR=./mullvad

# Admin bootstrap (used on first run only — creates admin user in DB)
PPVDA_ADMIN_USERNAME=admin
PPVDA_ADMIN_PASSWORD=
JWT_SECRET=

# Database
DB_PATH=./data/ppvda.db

# Darkreel CLI (server-wide — per-user creds are stored encrypted in DB)
DRK_BINARY_PATH=darkreel-cli
DRK_UPLOAD_TIMEOUT_MS=600000

# Job tracking
MAX_JOB_HISTORY=100

# Features
ENABLE_THUMBNAILS=false
