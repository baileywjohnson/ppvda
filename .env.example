PORT=3000
HOST=0.0.0.0
PROXY_URL=
DOWNLOAD_DIR=./downloads
BROWSER_TIMEOUT_MS=30000
NETWORK_IDLE_MS=5000
DOWNLOAD_TIMEOUT_MS=300000
FFMPEG_PATH=ffmpeg
MAX_CONCURRENT_DOWNLOADS=3
LOG_LEVEL=info

# Host filtering (comma-separated domains)
# Videos from preferred hosts are sorted first in extraction results
PREFERRED_HOSTS=
# Videos from blocked hosts are excluded from extraction results
BLOCKED_HOSTS=
# When set, ONLY videos from these hosts are returned (overrides BLOCKED_HOSTS)
ALLOWED_HOSTS=

# Mullvad VPN (auto-configures WireGuard tunnel on startup)
# Set both to enable. When active, all traffic routes through Mullvad — no PROXY_URL needed.
MULLVAD_ACCOUNT=
MULLVAD_LOCATION=
MULLVAD_CONFIG_DIR=./mullvad
